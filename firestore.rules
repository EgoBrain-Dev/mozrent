rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default safety net: Deny all reads/writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Listings Rules
    match /listings/{listingId} {
      allow read: if true;
      allow create, update, delete: if true; // In development/production sandbox, allow easy creation, update, and deletion of catalog listings
    }

    // Bookings Rules
    match /bookings/{bookingId} {
      allow read: if true;
      allow create, update, delete: if true; // Any client can create and update booking states (e.g. confirming paid references), and admin can delete/manage
    }

    // Feedbacks Rules
    match /feedbacks/{feedbackId} {
      allow read: if true;
      allow create: if true; // Any authenticated or sandbox user can write feedback
      allow update, delete: if false;
    }

    // Settings Rules
    match /settings/{settingId} {
      allow read, write: if true; // System settings and configurations are accessible for reading and updating
    }
  }
}
